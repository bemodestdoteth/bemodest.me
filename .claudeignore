# .claudeignore - Files to exclude from Claude context
# This file reduces token usage by ignoring generated/irrelevant files

# ============================================================================
# PYTHON VIRTUAL ENVIRONMENTS (highest impact - thousands of files)
# ============================================================================
.venv/
venv/
env/
ENV/
.venv-*/

# ============================================================================
# PYTHON CACHE & COMPILED FILES
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
.pyre/
.pytype/

# ============================================================================
# NODE.JS / JAVASCRIPT
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/

# ============================================================================
# BUILD & DISTRIBUTION ARTIFACTS
# ============================================================================
dist/
build/
*.egg-info/
.eggs/
*.egg
*.manifest
*.spec
*.lock

# ============================================================================
# LOG FILES
# ============================================================================
*.log
*.log.*
log/
logs/

# ============================================================================
# COVERAGE & TEST REPORTS
# ============================================================================
htmlcov/
.coverage
.coverage.*
.cache
coverage.xml
*.cover
.hypothesis/
.nox/

# ============================================================================
# IDE & EDITOR FILES
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-workspace
*.sublime-project

# ============================================================================
# DOCUMENTATION BUILD
# ============================================================================
site/
docs/_build/

# ============================================================================
# LARGE DATA FILES (optional - uncomment if data files shouldn't be in context)
# ============================================================================
# *.csv
# *.parquet
# *.json.gz
# *.pkl
# *.pickle

# ============================================================================
# PROJECT-SPECIFIC
# ============================================================================
.claude/skills/  # Claude skills directory if it contains large files
.import_linter_cache/
.codegraph/      # CodeGraph index files (regenerated as needed)

# Environment files (may contain secrets)
.env
.env.local
.env.*.local
test.env

# Git
.git/
