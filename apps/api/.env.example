MARKET_CACHE_UPDATE_INTERVAL_SEC=

# KIS / Hynix quotes
KIS_BASE_URL=
# Defaults to codys-private for KIS_API_ENVIRONMENT=prod and codys-private-dev otherwise.
KIS_API_STORE_DB=
KIS_API_STORE_COLLECTION=APIs
KIS_API_SERVICE_NAME=KIS
KIS_API_ENVIRONMENT=dev
# Set from /mnt/870-evo-1/server-dev/my-exchanges/.env in prod and /mnt/870-evo-1/server-dev/my-exchanges/test.env in dev.
DB_PASSPHRASE=
KIS_WS_URL=
KIS_WS_MOCK_URL=
KIS_WS_USE_MOCK=false
KIS_WS_ALLOW_INSECURE=false
KIS_NXT_APPROVAL_BASE_URL=
HYNIX_SK_HYNIX_SYMBOL=000660
HYNIX_ETF_SYMBOL=
HYNIX_ETF_NAME=
# /hynix reads SK hynix Hyperliquid futures from the sidecar ticker cache.
SIDECAR_URL=
HYNIX_NXT_TICK_TIMEOUT_MS=800
HYNIX_NXT_TICK_MAX_AGE_MS=10000

# Optional override for the built-in API ingest destination; defaults to http://127.0.0.1:${PORT}/api/alert-events/ingest.
BUILTIN_ALERT_INGEST_URL=
ALERT_DESTINATION_TAILSCALE_SUFFIX=.bemodest.me
ALERT_DESTINATION_ALLOW_LOOPBACK_IN_DEV=false
TELEGRAM_AGENT_DEV_WEBHOOK_BASE_URL=http://dev.bemodest.me:8091
TELEGRAM_AGENT_PROD_WEBHOOK_BASE_URL=http://api.bemodest.me:8091