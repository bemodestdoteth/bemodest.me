{
    "extends": "../tsconfig/base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@shared/*": [
                "src/shared/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ],
            "@services/*": [
                "src/services/*"
            ],
            "@bemodest/utils": [
                "../utils/src"
            ],
            "@bemodest/types": [
                "../types/src"
            ]
        }
    },
    "include": [
        "src/**/*.ts"
    ]
}