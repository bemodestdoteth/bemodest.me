{
  "$ref": "#/definitions/AlertRule",
  "definitions": {
    "AlertRule": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string"
        },
        "scope": {
          "type": "string",
          "enum": [
            "alert",
            "market_watch"
          ],
          "default": "alert"
        },
        "condition": {
          "type": "string",
          "enum": [
            "change_pct_5m",
            "change_pct_24h",
            "price_above",
            "price_below",
            "spread_pct",
            "volume_spike"
          ]
        },
        "cooldown_secs": {
          "type": "integer"
        },
        "created_at": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "exchanges": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "label": {
          "type": "string"
        },
        "minSources": {
          "type": "integer",
          "default": 2
        },
        "quote": {
          "type": "string"
        },
        "recovery_value": {
          "type": "number"
        },
        "ticker": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "value": {
          "type": "number"
        },
        "volumeFloorUsd": {
          "type": "number",
          "default": 30000
        },
        "destination_assignments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "destination_id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "dead": {
                "type": "boolean",
                "default": false
              },
              "last_failed_at": {
                "type": "string"
              }
            },
            "required": [
              "destination_id"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "alert_type_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "alert_type": {
                "type": "string",
                "enum": [
                  "normal",
                  "urgent"
                ]
              },
              "operator": {
                "type": "string",
                "enum": [
                  "gt",
                  "gte",
                  "lt",
                  "lte"
                ]
              },
              "value": {
                "type": "number"
              }
            },
            "required": [
              "alert_type",
              "operator",
              "value"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        }
      },
      "required": [
        "_id",
        "condition",
        "cooldown_secs",
        "enabled",
        "exchanges",
        "label",
        "quote",
        "recovery_value",
        "ticker",
        "value",
        "destination_assignments",
        "alert_type_rules"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}