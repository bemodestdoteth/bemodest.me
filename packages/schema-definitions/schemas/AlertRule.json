{
  "$ref": "#/definitions/AlertRule",
  "definitions": {
    "AlertRule": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string"
        },
        "condition": {
          "type": "string",
          "enum": [
            "change_pct_5m",
            "price_above",
            "price_below",
            "spread_pct",
            "volume_spike"
          ]
        },
        "cooldown_secs": {
          "type": "integer"
        },
        "created_at": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "exchanges": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "label": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        },
        "recovery_value": {
          "type": "number"
        },
        "ticker": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "value": {
          "type": "number"
        },
        "webhook_dead": {
          "type": "boolean",
          "default": false
        },
        "webhook_url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "_id",
        "condition",
        "cooldown_secs",
        "enabled",
        "exchanges",
        "label",
        "quote",
        "recovery_value",
        "ticker",
        "value",
        "webhook_url"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}