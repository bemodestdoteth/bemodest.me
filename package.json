{
  "name": "bemodest.me-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:all": "concurrently \"pnpm --filter api dev\" \"pnpm --filter extension watch\"",
    "build:extension": "pnpm --filter extension build",
    "watch:extension": "pnpm --filter extension watch"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "concurrently": "^9.1.2"
  }
}